# ─── Banco de dados PostgreSQL ────────────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/frostera_db"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Gere: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=substitua-por-uma-chave-forte-de-64-chars
JWT_EXPIRES_IN=7d

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── Frontend (CORS) ──────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
