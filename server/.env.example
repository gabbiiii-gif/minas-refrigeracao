# Porta do servidor WhatsApp (padrão: 3001)
PORT=3001

# Caminho do Chrome (detectado automaticamente se omitido)
# Windows: C:\Program Files\Google\Chrome\Application\chrome.exe
# macOS:   /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Linux:   /usr/bin/google-chrome
# CHROME_PATH=

# Chave secreta para proteger /send e /disconnect
# Gere uma chave forte: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WA_SECRET=coloque-aqui-sua-chave-secreta
